DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require
GROQ_API_KEY=gsk-your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_SERVICE_API_KEY=replace-with-a-long-random-internal-key
SERPAPI_API_KEY=your-serpapi-key
OPENCLAW_API_KEY=your-openclaw-key
REDIS_URL=rediss://:password@host:6379/0
ALLOWED_ORIGINS=http://localhost:3000,https://erp-frontend-rust.vercel.app
MAX_RESULT_ROWS=50
SCHEMA_CACHE_SECONDS=600
QUERY_CACHE_SECONDS=60
